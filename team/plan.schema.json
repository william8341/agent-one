{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentOne Team Plan",
  "type": "object",
  "required": ["goal", "steps"],
  "properties": {
    "goal": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "agent", "task"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "agent": { "type": "string", "minLength": 1 },
          "task": { "type": "string", "minLength": 1 },
          "inputs": {
            "type": "object",
            "additionalProperties": { "type": ["string", "number", "boolean"] },
            "default": {}
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "timeout_sec": { "type": "integer", "minimum": 1, "maximum": 7200 },
          "retry": { "type": "integer", "minimum": 0, "maximum": 3, "default": 0 },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        },
        "additionalProperties": false
      }
    },
    "final_aggregation": {
      "type": "object",
      "properties": {
        "format": { "type": "string", "enum": ["markdown"], "default": "markdown" },
        "sections": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["Conclusion", "Risks", "Next Actions"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
